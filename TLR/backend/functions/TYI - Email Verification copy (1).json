      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  const assignments = item.json.output?.[0]?.content?.[0]?.text?.assignments;\n\n  if (Array.isArray(assignments)) {\n    for (const assignment of assignments) {\n      assignment.start_date = assignment.start_date\n        ? new Date(assignment.start_date).toISOString()\n        : null;\n\n      assignment.due_date = assignment.due_date\n        ? new Date(assignment.due_date).toISOString()\n        : null;\n    }\n  }\n}\n\nreturn $input.all();"
      },
