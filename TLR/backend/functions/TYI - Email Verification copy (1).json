    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n\n  item.json.CourseTakenTitle = item.json.CourseTakenTitle\n    .split(\",\")\n    .map(c => c.trim());\n\n  item.json.CourseTakenGrade = item.json.CourseTakenGrade\n    .split(\",\")\n    .map(g => g.trim());\n\n}\n\nreturn $input.all();"
      },
      "id": "62c1d945-5acd-4d68-a834-674778c7ad46",
      "name": "strings to arrays",
      "type": "n8n-nodes-base.code",
