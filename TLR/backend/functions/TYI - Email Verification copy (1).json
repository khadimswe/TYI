    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const item = $input.item;\n\nconst titles = item.json.CourseTakenTitle;\nconst grades = item.json.CourseTakenGrade;\n\nitem.json.courses = titles.map((title, i) => ({\n  course: title,\n  grade: grades[i] || null\n}));\n\nreturn item;"
      },
      "id": "813f9a43-d876-4109-b697-95fedc857658",
      "name": "combining arrays",
      "type": "n8n-nodes-base.code",
